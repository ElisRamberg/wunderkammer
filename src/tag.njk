---
layout: base.njk
# One page per tag, at /tags/<tag>/. Eleventy's pagination loops over the
# auto-built list of tags (size: 1 = one tag per generated page).
pagination:
  data: collections.entryTags
  size: 1
  alias: tag
permalink: "/tags/{{ tag | slugify }}/"
eleventyComputed:
  title: "Tagged “{{ tag }}”"
---
{% from "card.njk" import card %}

<a class="back-link" href="/tags/">← all tags</a>
<h1 class="page-title">#{{ tag }}</h1>

<ul class="feed">
  {%- for entry in collections.entries %}
    {%- if tag in entry.data.tags %}
  {{ card(entry) }}
    {%- endif %}
  {%- endfor %}
</ul>
